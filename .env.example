# ─── MATP Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in real values before starting.
# Never commit .env to version control.

# ─── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=matp
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=matp

# ─── Security ──────────────────────────────────────────────────────────
# Webhook HMAC secret — must be at least 32 characters
WEBHOOK_SECRET=change_me_at_least_32_chars_here_

# AES-256-GCM master key for credential encryption — must be at least 32 chars
# Only the order-executor container reads this key.
MASTER_KEY=change_me_at_least_32_chars_here_

# ─── Service URLs (internal — do not change unless ports change) ───────
EXECUTOR_URL=http://order-executor:8004

# ─── Data feed (for Order Generator) ──────────────────────────────────
# Exchange to use for OHLCV market data (ccxt exchange id)
DATA_FEED_EXCHANGE=binance

# ─── Optional: override default ports ─────────────────────────────────
# LISTENER_PORT=8001
# GENERATOR_PORT=8002
# DASHBOARD_API_PORT=8003
# EXECUTOR_PORT=8004
# DASHBOARD_UI_PORT=3000
