# PostgreSQL
POSTGRES_PASSWORD=changeme

# Webhook shared secret (used by both Order Generator and TradingView alerts)
WEBHOOK_SECRET=changeme-long-random-string-min-32-chars

# Master key for encrypting exchange credentials stored in DB (AES-256-GCM)
MASTER_KEY=changeme-another-long-random-string-32chars

# Blofin Signal Bot
BLOFIN_API_KEY=
BLOFIN_API_SECRET=

# Hyperliquid
HYPERLIQUID_PRIVATE_KEY=

# Data feed source exchange for OHLCV (used by Order Generator)
DATA_FEED_EXCHANGE=binance
