# ─── MATP Environment Variables ───────────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env.
# Exchange API credentials are NOT set here — add them via the dashboard
# Accounts page after startup (see docs/setup.md).
# ──────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# User and DB are informational — postgres container uses these hardcoded values.
# WARNING: most services hardcode postgresql://matp:<password>@postgres:5432/matp
# in docker-compose.yml. Until that is updated, POSTGRES_PASSWORD must stay "matp"
# or you must also update every hardcoded DATABASE_URL in docker-compose.yml.
POSTGRES_USER=matp
POSTGRES_DB=matp
POSTGRES_PASSWORD=matp

# ─── Security ─────────────────────────────────────────────────────────────────
# AES-256-GCM master key for encrypting exchange credentials at rest.
# Read by order-listener and order-executor. Minimum 32 characters.
# Generate with: openssl rand -hex 32
MASTER_KEY=change_me_at_least_32_chars_here_

# ─── LLM providers ────────────────────────────────────────────────────────────
# At least one is required to run the AI signal generator and strategy-tester.
# The provider is chosen per-strategy in its AI config; that provider's key
# must be set. Leave unused providers blank.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional — news-feed enrichment for AI signals (CryptoPanic API key)
CRYPTOPANIC_API_KEY=

# ─── Public host ──────────────────────────────────────────────────────────────
# Your LAN IP or domain TradingView should send webhooks to.
# Used by dashboard-api to render each strategy's webhook URL in the dashboard.
# Leave blank to fall back to the request host header.
# Example: 192.168.1.100  or  matp.example.com
PUBLIC_HOST=

# ─── Strategy-tester tuning ───────────────────────────────────────────────────
# All optional — defaults are the values shown (from strategy-tester/app/config.py).
TESTER_DEFAULT_BALANCE=1000.0         # Paper balance per backtest run (USD)
TESTER_DEFAULT_FEE_PCT=0.02           # Taker fee % applied per trade
TESTER_DEFAULT_SLIPPAGE_PCT=0.05      # Simulated slippage % per fill
TESTER_MAX_CONCURRENT_RUNS=1          # Max simultaneous backtest runs
TESTER_LLM_FAILURE_THRESHOLD=0.05     # Max allowed LLM error rate before aborting run

# ─── Data feed ────────────────────────────────────────────────────────────────
# ccxt exchange id used by the order-generator for OHLCV market data.
DATA_FEED_EXCHANGE=binance

# ─── Notification service (Web Push VAPID) ──────────────────────────────────────
# Generate a keypair with py-vapid. Only the PUBLIC key goes here as a placeholder
# — never commit the private key.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
# Comma-separated exchanges to watch for stale ingestion heartbeats. Only
# exchanges with a running market-ingestion instance publish a heartbeat.
NOTIFICATION_EXCHANGES=blofin

# ─── Database URL (optional override) ─────────────────────────────────────────
# Only the ai-signal-generator reads this from the environment; all other services
# use a hardcoded URL in docker-compose.yml. Override only if needed.
# Must match POSTGRES_PASSWORD if you change it above.
# DATABASE_URL=postgresql://matp:matp@postgres:5432/matp

# ─── Optional: override default published ports ────────────────────────────────
# LISTENER_PORT=8001
# GENERATOR_PORT=8002
# DASHBOARD_API_PORT=8003
# EXECUTOR_PORT=8004
# AI_SIGNAL_PORT=8005
# TESTER_PORT=8006
# DASHBOARD_UI_PORT=3000
